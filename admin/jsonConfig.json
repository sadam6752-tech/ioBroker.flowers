{
  "i18n": true,
  "type": "tabs",
  "items": {
    "settings": {
      "type": "panel",
      "label": "Settings",
      "items": {
        "_telegramHeader": {
          "type": "header",
          "text": "Telegram Notifications",
          "size": 3
        },
        "telegramInstance": {
          "type": "instance",
          "label": "Telegram Instance",
          "adapter": "telegram",
          "default": "0",
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "telegramUsers": {
          "type": "text",
          "label": "Telegram Users",
          "help": "Comma-separated usernames or leave empty for all users",
          "placeholder": "user1,user2",
          "default": "",
          "xs": 12,
          "sm": 6,
          "md": 8,
          "lg": 8,
          "xl": 8
        },
        "_monitorHeader": {
          "type": "header",
          "text": "Monitoring",
          "size": 3
        },
        "checkInterval": {
          "type": "select",
          "label": "Check Interval",
          "options": [
            {
              "label": "5 minutes",
              "value": "5"
            },
            {
              "label": "15 minutes",
              "value": "15"
            },
            {
              "label": "30 minutes",
              "value": "30"
            },
            {
              "label": "1 hour",
              "value": "60"
            },
            {
              "label": "2 hours",
              "value": "120"
            },
            {
              "label": "6 hours",
              "value": "360"
            },
            {
              "label": "24 hours",
              "value": "1440"
            }
          ],
          "default": "60",
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 3,
          "xl": 3
        },
        "maxMessagesPerDay": {
          "type": "number",
          "label": "Max Messages per Day",
          "min": 1,
          "max": 100,
          "default": 10,
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 3,
          "xl": 3
        },
        "repeatInterval": {
          "type": "number",
          "label": "Repeat Interval (min)",
          "help": "Repeat alert interval in minutes if threshold is still exceeded (0 = no repeat)",
          "min": 0,
          "max": 1440,
          "default": 60,
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 3,
          "xl": 3
        },
        "offlineThreshold": {
          "type": "number",
          "label": "Offline Threshold (hours)",
          "min": 1,
          "max": 48,
          "default": 3,
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 3,
          "xl": 3
        },
        "_nightHeader": {
          "type": "header",
          "text": "Night Mode",
          "size": 3
        },
        "nightModeEnabled": {
          "type": "checkbox",
          "label": "Enable Night Mode",
          "default": false,
          "xs": 12,
          "sm": 4,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "nightModeStart": {
          "type": "text",
          "label": "Night Mode Start",
          "default": "22:00",
          "disabled": "!data.nightModeEnabled",
          "xs": 12,
          "sm": 4,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "nightModeEnd": {
          "type": "text",
          "label": "Night Mode End",
          "default": "08:00",
          "disabled": "!data.nightModeEnabled",
          "xs": 12,
          "sm": 4,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "_reportHeader": {
          "type": "header",
          "text": "Periodic Reports",
          "size": 3
        },
        "dailyReportEnabled": {
          "type": "checkbox",
          "label": "Daily Report",
          "default": false,
          "xs": 12,
          "sm": 4,
          "md": 3,
          "lg": 3,
          "xl": 3
        },
        "dailyReportTime": {
          "type": "text",
          "label": "Daily Report Time",
          "default": "20:00",
          "disabled": "!data.dailyReportEnabled",
          "xs": 12,
          "sm": 4,
          "md": 3,
          "lg": 3,
          "xl": 3
        },
        "weeklyReportEnabled": {
          "type": "checkbox",
          "label": "Weekly Report",
          "default": false,
          "xs": 12,
          "sm": 4,
          "md": 3,
          "lg": 3,
          "xl": 3
        },
        "weeklyReportDay": {
          "type": "select",
          "label": "Weekly Report Day",
          "options": [
            {
              "label": "Monday",
              "value": "1"
            },
            {
              "label": "Tuesday",
              "value": "2"
            },
            {
              "label": "Wednesday",
              "value": "3"
            },
            {
              "label": "Thursday",
              "value": "4"
            },
            {
              "label": "Friday",
              "value": "5"
            },
            {
              "label": "Saturday",
              "value": "6"
            },
            {
              "label": "Sunday",
              "value": "0"
            }
          ],
          "default": "1",
          "disabled": "!data.weeklyReportEnabled",
          "xs": 12,
          "sm": 4,
          "md": 3,
          "lg": 3,
          "xl": 3
        },
        "weeklyReportTime": {
          "type": "text",
          "label": "Weekly Report Time",
          "default": "10:00",
          "disabled": "!data.weeklyReportEnabled",
          "xs": 12,
          "sm": 4,
          "md": 3,
          "lg": 3,
          "xl": 3
        }
      }
    },
    "plants": {
      "type": "panel",
      "label": "Plants",
      "items": {
        "_plantsInfo": {
          "type": "staticText",
          "text": "Add your plants here. Select the ioBroker state IDs for each sensor. Thresholds override the selected profile values.",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "plants": {
          "type": "table",
          "label": "Plants",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "items": [
            {
              "type": "text",
              "title": "Name",
              "attr": "name",
              "width": "13%"
            },
            {
              "type": "text",
              "title": "Location",
              "attr": "location",
              "width": "9%"
            },
            {
              "type": "select",
              "title": "Profile",
              "attr": "profile",
              "width": "10%",
              "options": [
                {
                  "label": "Ficus",
                  "value": "Ficus"
                },
                {
                  "label": "Orchid",
                  "value": "Orchid"
                },
                {
                  "label": "Cactus",
                  "value": "Cactus"
                },
                {
                  "label": "Monstera",
                  "value": "Monstera"
                },
                {
                  "label": "Fern",
                  "value": "Fern"
                },
                {
                  "label": "Succulent",
                  "value": "Succulent"
                },
                {
                  "label": "Palm",
                  "value": "Palm"
                },
                {
                  "label": "Pothos",
                  "value": "Pothos"
                },
                {
                  "label": "Aloe Vera",
                  "value": "AloeVera"
                },
                {
                  "label": "Peace Lily",
                  "value": "PeaceLily"
                },
                {
                  "label": "Coffea arabica",
                  "value": "CoffeaArabica"
                },
                {
                  "label": "Rhapis excelsa",
                  "value": "RhapisExcelsa"
                },
                {
                  "label": "Calathea zebrina",
                  "value": "Calathea"
                },
                {
                  "label": "Sansevieria Laurentii",
                  "value": "Sansevieria"
                },
                {
                  "label": "Custom",
                  "value": "Custom"
                }
              ]
            },
            {
              "type": "objectId",
              "title": "Humidity Sensor",
              "attr": "sensorHumidity",
              "width": "14%"
            },
            {
              "type": "objectId",
              "title": "Temperature Sensor",
              "attr": "sensorTemperature",
              "width": "14%"
            },
            {
              "type": "objectId",
              "title": "Battery Sensor",
              "attr": "sensorBattery",
              "width": "9%"
            },
            {
              "type": "text",
              "title": "Hum Min %",
              "attr": "humidityMin",
              "width": "5%",
              "placeholder": "—"
            },
            {
              "type": "text",
              "title": "Hum Max %",
              "attr": "humidityMax",
              "width": "5%",
              "placeholder": "—"
            },
            {
              "type": "text",
              "title": "Temp Min",
              "attr": "temperatureMin",
              "width": "5%",
              "placeholder": "—"
            },
            {
              "type": "text",
              "title": "Temp Max",
              "attr": "temperatureMax",
              "width": "5%",
              "placeholder": "—"
            },
            {
              "type": "text",
              "title": "Bat Min %",
              "attr": "batteryMin",
              "width": "7%",
              "placeholder": "—"
            },
            {
              "type": "checkbox",
              "title": "Enabled",
              "attr": "enabled",
              "width": "4%"
            }
          ]
        }
      }
    },
    "profiles": {
      "type": "panel",
      "label": "Profiles",
      "items": {
        "_profilesInfo": {
          "type": "staticText",
          "text": "Built-in plant profiles with recommended thresholds. Select a profile in the Plants tab — thresholds will be applied automatically. You can override individual values per plant.",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "_profileTable": {
          "type": "table",
          "label": "",
          "noDelete": true,
          "noAdd": true,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "default": [
            {
              "profile": "Ficus",
              "humidity": "40–70%",
              "temperature": "18–25°C",
              "watering": "7"
            },
            {
