            },
            {
              "profile": "Custom",
              "humidity": "—",
              "temperature": "—",
              "watering": "—"
            }
          ],
          "items": [
            {
              "type": "text",
              "title": "Profile",
              "attr": "profile",
              "width": "30%",
              "readOnly": true
            },
            {
              "type": "text",
              "title": "Humidity %",
              "attr": "humidity",
              "width": "25%",
