              "watering": "14"
            },
            {
              "profile": "Palm",
              "humidity": "40–60%",
              "temperature": "18–27°C",
              "watering": "7"
            },
            {
              "profile": "Pothos",
              "humidity": "40–60%",
              "temperature": "15–27°C",
              "watering": "7"
            },
            {
              "profile": "Aloe Vera",
              "humidity": "10–30%",
              "temperature": "15–30°C",
              "watering": "14"
            },
            {
              "profile": "Peace Lily",
              "humidity": "50–70%",
              "temperature": "18–27°C",
              "watering": "5"
            },
            {
              "profile": "Coffea arabica",
              "humidity": "60–80%",
              "temperature": "18–27°C",
              "watering": "7"
            },
            {
              "profile": "Rhapis excelsa",
              "humidity": "40–60%",
              "temperature": "15–25°C",
              "watering": "10"
            },
            {
              "profile": "Calathea zebrina",
              "humidity": "60–80%",
              "temperature": "18–29°C",
